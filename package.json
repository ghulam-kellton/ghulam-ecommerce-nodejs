{
  "name": "scalable-ecommerce-api",
  "version": "1.0.0",
  "description": "Clean Architecture E-commerce Backend",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
