              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "// Use your actual response structure: { status: 'success', data: { category: { _id: \"...\" } } }",
                  "if (jsonData.data && jsonData.data.category && jsonData.data.category._id) {",
                  "    pm.environment.set(\"category_id\", jsonData.data.category._id);",
                  "} else if (jsonData.data && jsonData.data._id) {",
                  "    pm.environment.set(\"category_id\", jsonData.data._id);",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
