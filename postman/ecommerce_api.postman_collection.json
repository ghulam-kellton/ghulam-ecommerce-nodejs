    {
      "name": "3. Product Management",
      "item": [
        {
          "name": "List All Products",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/products",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "products"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Create Product",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Parse the response",
                  "var jsonData = pm.response.json();",
                  "",
                  "// Based on your controller: res.status(201).json({ status: 'success', data: { product } });",
                  "if (jsonData.data && jsonData.data.product && jsonData.data.product._id) {",
                  "    var id = jsonData.data.product._id;",
                  "    pm.environment.set(\"product_id\", id);",
                  "    console.log(\"Product ID saved successfully: \" + id);",
                  "} else {",
                  "    console.log(\"Could not find product _id in response. Check the Console (Ctrl+Alt+C)\");",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "name",
                  "value": "MacBook Pro",
                  "type": "text"
                },
                {
                  "key": "price",
                  "value": "2400",
                  "type": "text"
                },
                {
                  "key": "description",
                  "value": "M3 Chip Laptop",
                  "type": "text"
                },
                {
                  "key": "category",
                  "value": "{{category_id}}",
                  "type": "text"
                },
                {
                  "key": "stock",
                  "value": "10",
                  "type": "text"
                },
                {
                  "key": "images",
                  "type": "file",
                  "value": null
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/products",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "products"
              ]
            }
          },
          "response": []
        },
